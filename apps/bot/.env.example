# Required: create a bot with @BotFather and paste its token here.
TELEGRAM_BOT_TOKEN=

# Optional. Default research model for /research and the daily digest (haiku is cheapest
# on the Claude subscription; "sonnet" is deeper). Per-command override: /research AAPL sonnet
RESEARCH_MODEL=haiku

# Optional. Local hour (0-23) for the daily AI digest. Default 8.
DAILY_HOUR=8

# Optional. Where the per-chat watchlist JSON is stored. Default apps/bot/data.
# BOT_DATA_DIR=/var/lib/smartinvest-bot

# Optional. Telegram long-poll timeout in seconds. Default 30.
# POLL_TIMEOUT=30

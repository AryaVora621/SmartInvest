# Copy to .env for local/self-host runs. All keys are optional.

# Secret-store and cache paths default to absolute locations under the web app dir
# (set by next.config.ts). Override only if you need a custom location:
# SECRETS_PATH=/abs/path/.secrets.json
# AI_CACHE_DIR=/abs/path/.cache

# Optional data-provider keys (read from the environment):
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=

# Test/dev seam: when set to 1, /api/ai-research streams a canned report instead of
# invoking the real engine (used by the route tests).
# AI_RESEARCH_FAKE=1
